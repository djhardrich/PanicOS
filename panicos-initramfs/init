#!/bin/sh
# PanicOS initramfs — find boot + storage partitions, loop-mount the selected
# squashfs, then set up TWO overlayfs layers before switch_root:
#
#   1. Rootfs overlay  — squashfs as lower, per-flavor upper on the ext4.
#                        Each squashfs boots into its own pristine-but-writable
#                        rootfs; changes are captured per-flavor.
#
#   2. Storage overlay — empty shared/ dir as lower, per-flavor upper on the
#                        ext4.  Each squashfs sees its own isolated /storage;
#                        ROCKNIX's games-internal/.cache/iwd/etc. and PanicOS's
#                        .emulationstation/.config/ cannot bleed into each other.
#
# The raw ext4 is exposed at /storage-base in the running OS so admin tools
# (PanicOS-SquashFS-Install.sh, migration scripts) can inspect or seed the
# shared/ area without going through any overlay.
#
# Directory layout inside the ext4 (all under .panicos-overlay/):
#   .panicos-overlay/shared/            — storage overlay lower (read-only base)
#   .panicos-overlay/<flavor>/upper/    — rootfs overlay upper
#   .panicos-overlay/<flavor>/work/     — rootfs overlay work
#   .panicos-overlay/<flavor>/storage/  — storage overlay upper
#   .panicos-overlay/<flavor>/swork/    — storage overlay work
#
# Detection:
#   Boot partition    = vfat with /panicos-active.cfg at the root.
#   Storage partition = ext4, the other writable partition.

set -e

PATH=/bin:/sbin:/usr/bin:/usr/sbin
export PATH

mkdir -p /proc /sys /dev /run /boot /storage-base /storage /sysroot
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
# Allwinner boot0 starts the hardware watchdog; kick it now or the device
# reboots before init completes. Mirrors what Knulli's initramfs does.
exec < /dev/console > /dev/console 2>&1 || true
watchdog -t 15 /dev/watchdog0 2>/dev/null || true
mount -t tmpfs tmpfs /run

panic() {
    echo "PANIC: $*" >&2
    echo "Dropping to shell. Type exit to reboot." >&2
    /bin/sh
    reboot -f
}

# Wait for the kernel to enumerate ALL partitions. Stop when count is stable.
prev_count=-1
i=0
while [ $i -lt 50 ]; do
    cur_count=$(ls /dev/mmcblk*p* /dev/sd*[0-9] 2>/dev/null | wc -l)
    [ "$cur_count" -gt 0 ] && [ "$cur_count" = "$prev_count" ] && break
    prev_count=$cur_count
    sleep 0.1
    i=$((i+1))
done

echo ">>> PanicOS initramfs: block devices visible:"
ls -l /dev/mmcblk*p* /dev/sd*[0-9] 2>/dev/null | sed 's/^/    /'

find_boot() {
    for dev in /dev/mmcblk*p* /dev/sd*[0-9]; do
        [ -b "$dev" ] || continue
        if mount -o ro -t vfat "$dev" /boot 2>/dev/null; then
            if [ -f /boot/panicos-active.cfg ]; then
                echo ">>> PanicOS initramfs: boot partition = $dev"
                return 0
            fi
            umount /boot
        fi
    done
    return 1
}

find_storage() {
    boot_dev="$1"
    echo ">>> PanicOS initramfs: looking for storage (skip boot=$boot_dev)"
    for dev in /dev/mmcblk*p* /dev/sd*[0-9]; do
        [ -b "$dev" ] || continue
        [ "$dev" = "$boot_dev" ] && continue
        echo "    trying $dev"
        if mount -t ext4 "$dev" /storage-base 2>/dev/null; then
            echo ">>> PanicOS initramfs: storage partition = $dev"
            return 0
        else
            echo "    $dev not ext4 (or mount failed), skipping"
        fi
    done
    return 1
}

find_boot || panic "no boot partition with /panicos-active.cfg found"
BOOT_DEV=$(awk '$2 == "/boot" {print $1}' /proc/mounts | head -1)

IMAGE=
FLAVOR=
. /boot/panicos-active.cfg
[ -n "$IMAGE" ] || panic "IMAGE not set in /boot/panicos-active.cfg"

# ---- Multiboot menu ----------------------------------------------------------
flavors=""
for sq in /boot/*.squashfs; do
    [ -e "$sq" ] && flavors="$flavors ${sq##*/}"
done
flavor_count=$(echo $flavors | wc -w)

if [ -x /sbin/panicos-mbselect ] && [ "$flavor_count" -gt 1 ]; then
    for _ko in /*.ko; do
        [ -f "$_ko" ] && insmod "$_ko" 2>/dev/null || true
    done
    sleep 1
    echo ">>> PanicOS initramfs: booting $IMAGE in 3s — press any button for menu"
    if /sbin/panicos-mbselect wait 3; then
        if chosen=$(/sbin/panicos-mbselect menu "$IMAGE" $flavors); then
            if [ -n "$chosen" ] && [ -f "/boot/$chosen" ]; then
                IMAGE="$chosen"
                FLAVOR=
                echo ">>> PanicOS initramfs: user selected $IMAGE"
            fi
        fi
    fi
fi
# ------------------------------------------------------------------------------

# FLAVOR derives from the IMAGE filename (strip .squashfs). Each squashfs gets
# completely isolated rootfs AND storage overlays. Override via panicos-active.cfg
# to share state between two squashfs files.
if [ -z "$FLAVOR" ]; then
    FLAVOR="${IMAGE%.squashfs}"
fi
echo ">>> PanicOS initramfs: booting $IMAGE (flavor=$FLAVOR)"

[ -f "/boot/$IMAGE" ] || panic "/boot/$IMAGE not found on boot partition"

# Loop-mount the squashfs (read-only lower layer for the rootfs overlay).
mkdir -p /lower
LOOPDEV=$(losetup -f)
losetup -r "$LOOPDEV" "/boot/$IMAGE" \
    || panic "losetup of /boot/$IMAGE failed"
mount -o ro -t squashfs "$LOOPDEV" /lower \
    || panic "mount of squashfs failed"

# Mount the storage ext4. Fall back to tmpfs (non-persistent) if not found.
if find_storage "$BOOT_DEV"; then
    :
else
    echo ">>> PanicOS initramfs: no storage partition found; using tmpfs (non-persistent)"
    mount -t tmpfs tmpfs /storage-base
fi

# ── Overlay directory layout ──────────────────────────────────────────────────
OV_BASE=/storage-base/.panicos-overlay/$FLAVOR

# Rootfs overlay dirs (upper/work kept at old names for backward compat with
# existing devices that already have an upper/ populated with module injections,
# ES configs, etc.)
mkdir -p "$OV_BASE/upper" "$OV_BASE/work"

# Per-flavor storage dir — bind-mounted to /storage so it stays on ext4.
# A plain overlayfs here would make /storage an overlayfs itself, which
# breaks any guest OS (e.g. ROCKNIX) that mounts its own overlays with
# upperdir/workdir under /storage (kernel rejects overlayfs-on-overlayfs
# without allow_nesting, which this kernel does not support).
mkdir -p "$OV_BASE/storage"

# ── Rootfs overlayfs ─────────────────────────────────────────────────────────
mount -t overlay panicos-rootfs \
    -o lowerdir=/lower,upperdir="$OV_BASE/upper",workdir="$OV_BASE/work" \
    /sysroot \
    || panic "rootfs overlayfs mount failed"

# ── Storage bind mount ───────────────────────────────────────────────────────
# Bind-mount the per-flavor directory directly so /storage is ext4-backed.
# Each flavor sees its own isolated directory; guest OSes can mount their
# own overlays with upper/workdir under /storage without issue.
mount --bind "$OV_BASE/storage" /storage \
    || panic "storage bind mount failed"

# ── Module / firmware injection for foreign squashfs (e.g. ROCKNIX, Debian) ──
# If the squashfs lacks /lib/modules/<kver> for our running kernel, inject from
# the boot partition's panicos-modules.tar.gz into the rootfs overlay upper.
# Sentinel prevents re-injection on every boot; new kver busts it automatically.
_kver=$(uname -r)
_sentinel="$OV_BASE/upper/.panicos-modules-$_kver"
# Match the running kernel: the RT kernel (uname -r ends in -rt) has its own
# module tree shipped as panicos-modules-rt.tar.gz; the non-RT default uses
# panicos-modules.tar.gz. Picking the wrong one leaves the kernel with no
# loadable modules (vermagic mismatch).
case "$_kver" in
    *-rt) _modules_tar="/boot/panicos-modules-rt.tar.gz" ;;
    *)    _modules_tar="/boot/panicos-modules.tar.gz" ;;
esac
if [ ! -d "/lower/lib/modules/$_kver" ] && \
   [ ! -d "/lower/usr/lib/modules/$_kver" ] && \
   [ -f "$_modules_tar" ] && \
   [ ! -f "$_sentinel" ]; then
    echo ">>> PanicOS: injecting kernel modules+firmware into $FLAVOR overlay..."
    tar -xzf "$_modules_tar" -C "$OV_BASE/upper" 2>/dev/null && \
        touch "$_sentinel" && \
        echo ">>> PanicOS: injection done (kernel $_kver)" || \
        echo ">>> PanicOS: injection failed — device drivers may be missing"
    _mld="$OV_BASE/upper/etc/modules-load.d"
    mkdir -p "$_mld"
    printf 'rocknix-joypad\nrocknix-singleadc-joypad\n' \
        > "$_mld/panicos-joypad.conf" || true
fi
# ─────────────────────────────────────────────────────────────────────────────

# Move all initramfs mounts into sysroot before switch_root.
# /lower is the squashfs lowerdir — kernel holds a VFS ref, EBUSY to move it;
# leave it, switch_root's tmpfs teardown releases it.
# /storage-base (raw ext4) is exposed so running-OS tools can inspect/seed the
# shared/ area or run storage migration without going through an overlay.
for m in proc sys dev run boot storage-base storage; do
    mkdir -p "/sysroot/$m"
    mount --move "/$m" "/sysroot/$m" || panic "mount --move /$m failed"
done

exec switch_root /sysroot /sbin/init || panic "switch_root failed"

#!/bin/sh
# PanicOS initramfs — find boot + system partitions on whichever block
# device our SD card / eMMC ended up as, loop-mount the selected
# squashfs, and switch_root into it.
#
# Detection strategy:
#   - Boot partition = vfat with /panicos-active.cfg at the root.
#   - System partition = ext4 with at least one .squashfs file at root.
#
# Avoids hardcoding /dev/mmcblkN, /dev/sdN, etc. — works the same on:
#   - Built-from-source flavors where SD card is mmcblk0
#   - Vendor-blob flavors (TrimUI Brick) where SD card is mmcblk1
#   - Any future device with a different enumeration

set -e

PATH=/bin:/sbin:/usr/bin:/usr/sbin
export PATH

mkdir -p /proc /sys /dev /run /boot /system /sysroot
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs tmpfs /run

panic() {
    echo "PANIC: $*" >&2
    echo "Dropping to shell. Type exit to reboot." >&2
    /bin/sh
    reboot -f
}

# Wait briefly for partition devices to appear (settles after kernel
# probes mmc/scsi).
i=0
while [ $i -lt 20 ]; do
    [ -e /dev/mmcblk0p1 ] || [ -e /dev/mmcblk1p1 ] || [ -e /dev/sda1 ] && break
    sleep 0.1
    i=$((i+1))
done

# Find the boot partition: a vfat with /panicos-active.cfg at root.
find_boot() {
    for dev in /dev/mmcblk*p* /dev/sd*[0-9]; do
        [ -b "$dev" ] || continue
        if mount -o ro -t vfat "$dev" /boot 2>/dev/null; then
            if [ -f /boot/panicos-active.cfg ]; then
                echo ">>> PanicOS initramfs: boot partition = $dev"
                return 0
            fi
            umount /boot
        fi
    done
    return 1
}

# Find the system partition: an ext4 with at least one .squashfs at root.
# Skip whatever boot device we already mounted.
find_system() {
    boot_dev="$1"
    for dev in /dev/mmcblk*p* /dev/sd*[0-9]; do
        [ -b "$dev" ] || continue
        [ "$dev" = "$boot_dev" ] && continue
        if mount -o ro -t ext4 "$dev" /system 2>/dev/null; then
            if ls /system/*.squashfs >/dev/null 2>&1; then
                echo ">>> PanicOS initramfs: system partition = $dev"
                return 0
            fi
            umount /system
        fi
    done
    return 1
}

find_boot || panic "no boot partition with /panicos-active.cfg found"
BOOT_DEV=$(awk '$2 == "/boot" {print $1}' /proc/mounts | head -1)

# Default IMAGE in case panicos-active.cfg is malformed.
IMAGE=
. /boot/panicos-active.cfg
[ -n "$IMAGE" ] || panic "IMAGE not set in /boot/panicos-active.cfg"

echo ">>> PanicOS initramfs: booting $IMAGE"

find_system "$BOOT_DEV" || panic "no system partition with squashfs found"

[ -f "/system/$IMAGE" ] || panic "/system/$IMAGE not found"

LOOPDEV=$(losetup -f)
losetup -r "$LOOPDEV" "/system/$IMAGE" \
    || panic "losetup of /system/$IMAGE failed"

mount -o ro -t squashfs "$LOOPDEV" /sysroot \
    || panic "mount of squashfs failed"

for m in proc sys dev run boot system; do
    mkdir -p "/sysroot/$m"
    mount --move "/$m" "/sysroot/$m"
done

exec switch_root /sysroot /sbin/init

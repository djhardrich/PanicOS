#!/bin/sh
# PanicOS initramfs — find boot + storage partitions on whichever block
# device our SD card / eMMC ended up as, loop-mount the selected squashfs
# (which lives on the boot vfat alongside the kernel — Knulli/ROCKNIX
# style), set up an overlayfs whose upper+work directories live on the
# storage ext4 partition, and switch_root into the merged tree.
#
# Net effect: rootfs presents as fully writable from userspace, but only
# changes (deltas) get written; the base squashfs stays pristine. PC
# users see the boot vfat → can drop new squashfs flavors / edit active.cfg.
#
# Detection strategy (no hardcoded mmcblkN/sdN):
#   - Boot partition    = vfat with /panicos-active.cfg at the root.
#                          Squashfs flavor(s) live on this partition too.
#   - Storage partition = ext4, the *other* writable partition. Holds user
#                          data and .panicos-overlay/{upper,work}.

set -e

PATH=/bin:/sbin:/usr/bin:/usr/sbin
export PATH

mkdir -p /proc /sys /dev /run /boot /storage /sysroot
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs tmpfs /run

panic() {
    echo "PANIC: $*" >&2
    echo "Dropping to shell. Type exit to reboot." >&2
    /bin/sh
    reboot -f
}

# Wait for the kernel to enumerate ALL partitions on whichever mmc we
# booted from. Stop as soon as we see a stable count two ticks in a row.
prev_count=-1
i=0
while [ $i -lt 50 ]; do
    cur_count=$(ls /dev/mmcblk*p* /dev/sd*[0-9] 2>/dev/null | wc -l)
    [ "$cur_count" -gt 0 ] && [ "$cur_count" = "$prev_count" ] && break
    prev_count=$cur_count
    sleep 0.1
    i=$((i+1))
done

echo ">>> PanicOS initramfs: block devices visible:"
ls -l /dev/mmcblk*p* /dev/sd*[0-9] 2>/dev/null | sed 's/^/    /'

find_boot() {
    for dev in /dev/mmcblk*p* /dev/sd*[0-9]; do
        [ -b "$dev" ] || continue
        if mount -o ro -t vfat "$dev" /boot 2>/dev/null; then
            if [ -f /boot/panicos-active.cfg ]; then
                echo ">>> PanicOS initramfs: boot partition = $dev"
                return 0
            fi
            umount /boot
        fi
    done
    return 1
}

find_storage() {
    boot_dev="$1"
    echo ">>> PanicOS initramfs: looking for storage (skip boot=$boot_dev)"
    for dev in /dev/mmcblk*p* /dev/sd*[0-9]; do
        [ -b "$dev" ] || continue
        [ "$dev" = "$boot_dev" ] && continue
        echo "    trying $dev"
        if mount -t ext4 "$dev" /storage 2>/dev/null; then
            echo ">>> PanicOS initramfs: storage partition = $dev"
            return 0
        else
            echo "    $dev not ext4 (or mount failed), skipping"
        fi
    done
    return 1
}

find_boot || panic "no boot partition with /panicos-active.cfg found"
BOOT_DEV=$(awk '$2 == "/boot" {print $1}' /proc/mounts | head -1)

IMAGE=
FLAVOR=
. /boot/panicos-active.cfg
[ -n "$IMAGE" ] || panic "IMAGE not set in /boot/panicos-active.cfg"

# ---- Multiboot menu ------------------------------------------------------
# If multiple .squashfs flavors exist on the boot vfat AND we have the
# mbselect helper, give the user a 3-second window to interrupt and pick a
# different one. Without an interrupt or with only one flavor present, fall
# through to the default IMAGE that active.cfg pointed at.
#
# Gamepad input requires the rocknix-joypad driver which is out-of-tree —
# it ships in the initramfs at /rocknix-joypad.ko (build-initramfs.sh
# bundles it). Insmod is best-effort; mbselect falls back to whatever
# evdev devices already exist (gpio-keys volume buttons, USB keyboard,
# etc.) if the joypad module is missing or fails to load.
flavors=""
for sq in /boot/*.squashfs; do
    [ -e "$sq" ] && flavors="$flavors ${sq##*/}"
done
flavor_count=$(echo $flavors | wc -w)

if [ -x /sbin/panicos-mbselect ] && [ "$flavor_count" -gt 1 ]; then
    for _ko in /*.ko; do
        [ -f "$_ko" ] && insmod "$_ko" 2>/dev/null || true
    done
    sleep 1   # let evdev nodes settle after insmod
    echo ">>> PanicOS initramfs: booting $IMAGE in 3s — press any button for menu"
    if /sbin/panicos-mbselect wait 3; then
        chosen=$(/sbin/panicos-mbselect menu "$IMAGE" $flavors)
        if [ -n "$chosen" ] && [ -f "/boot/$chosen" ]; then
            IMAGE="$chosen"
            FLAVOR=
            echo ">>> PanicOS initramfs: user selected $IMAGE"
        fi
    fi
fi
# -------------------------------------------------------------------------

# Per-flavor overlay namespace: each squashfs gets its own
# /storage/.panicos-overlay/<flavor>/{upper,work}. Switching flavors keeps
# each one's deltas separate (Debian-vs-Arch /etc would be chaos otherwise).
# User data on /storage outside .panicos-overlay/ is shared across flavors.
#
# Default FLAVOR derives from the IMAGE filename minus .squashfs — simple,
# unambiguous, no parsing of device-prefix needed. Override by setting
# FLAVOR= in panicos-active.cfg if you want two squashfses to share state.
if [ -z "$FLAVOR" ]; then
    FLAVOR="${IMAGE%.squashfs}"
fi
echo ">>> PanicOS initramfs: booting $IMAGE (flavor=$FLAVOR)"

[ -f "/boot/$IMAGE" ] || panic "/boot/$IMAGE not found on boot partition"

# Loop-mount the selected squashfs at /lower (the overlayfs lower layer).
mkdir -p /lower
LOOPDEV=$(losetup -f)
losetup -r "$LOOPDEV" "/boot/$IMAGE" \
    || panic "losetup of /boot/$IMAGE failed"
mount -o ro -t squashfs "$LOOPDEV" /lower \
    || panic "mount of squashfs failed"

# Find + mount the storage ext4 partition (rw). If absent we fall back to
# tmpfs upper so the system still boots, just non-persistent.
if find_storage "$BOOT_DEV"; then
    :
else
    echo ">>> PanicOS initramfs: no storage partition found; using tmpfs (non-persistent)"
    mount -t tmpfs tmpfs /storage
fi

OVERLAY_BASE=/storage/.panicos-overlay/$FLAVOR
mkdir -p "$OVERLAY_BASE/upper" "$OVERLAY_BASE/work"

mount -t overlay panicos-overlay \
    -o lowerdir=/lower,upperdir="$OVERLAY_BASE/upper",workdir="$OVERLAY_BASE/work" \
    /sysroot \
    || panic "overlayfs mount failed"

for m in proc sys dev run boot storage lower; do
    mkdir -p "/sysroot/$m"
    mount --move "/$m" "/sysroot/$m"
done

exec switch_root /sysroot /sbin/init

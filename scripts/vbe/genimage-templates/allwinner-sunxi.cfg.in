# Allwinner sunxi disk image — generated by vbe build-image.
#
# MBR layout (mirrors board/anbernic/rg35xx-pro/genimage.cfg.in for two-blob mode):
#   Offset 8K  (0x2000):   boot0.img  — Allwinner eGON SPL (stage1 BROM blob)
#   Offset 16M (0x1000000): boot_package.fex — Allwinner TOC1 (U-Boot+ATF+SCP+DTB)
#                            Only staged if present in the archive.
#   boot  FAT32 partition (kernel Image + DTBs + boot.scr, bootable)
#   system ext4 partition (squashfs payload)
#   overlay ext4 partition (writable user data)
#
# Envsubst tokens: PANICOS_OUTPUT_NAME, PANICOS_BOOT_PARTITION_SIZE_MB,
#   PANICOS_SYSTEM_PARTITION_SIZE_MB, PANICOS_OVERLAY_PARTITION_INITIAL_SIZE_MB,
#   PANICOS_AW_HAS_BOOT_PACKAGE (set to "1" if boot_package.fex is present,
#   but genimage doesn't support conditionals — cmd-build-image.sh renders the
#   relevant partition block directly into the config via envsubst).

image boot.vfat {
	vfat {
		files = {
			"Image",
			"dtb.img",
			"dtbs",
			"boot.scr",
			"panicos-active.cfg",
			"initramfs.cpio.gz",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image system.ext4 {
	ext4 { }
	size = ${PANICOS_SYSTEM_PARTITION_SIZE_MB}M
}

image overlay.ext4 {
	ext4 { }
	size = ${PANICOS_OVERLAY_PARTITION_INITIAL_SIZE_MB}M
}

image ${PANICOS_OUTPUT_NAME}.img {
	hdimage { }

	partition spl {
		in-partition-table = "no"
		image = "boot0.img"
		offset = 8K
	}

${PANICOS_AW_BOOT_PACKAGE_BLOCK}
	partition boot {
		partition-type = 0xC
		bootable = "true"
		image = "boot.vfat"
	}

	partition system {
		partition-type = 0x83
		image = "system.ext4"
	}

	partition overlay {
		partition-type = 0x83
		image = "overlay.ext4"
	}
}

# Allwinner sunxi disk image — generated by vbe build-image.
# Two-partition design (matches board/anbernic/rg35xx-pro/genimage.cfg.in):
#   Offset 8K  (0x2000):    boot0.img — Allwinner eGON SPL (stage1 BROM blob)
#   Offset 16M (0x1000000): boot_package.fex — Allwinner TOC1 (U-Boot+ATF+SCP+DTB)
#                             Only staged if present in the archive.
#   boot     FAT32 — kernel Image + DTB(s) + extlinux.conf + *.squashfs flavors
#                    + panicos-active.cfg
#   storage  ext4  — user data + .panicos-overlay/ (firstboot grows to fill SD)
#
# Envsubst tokens: PANICOS_OUTPUT_NAME, PANICOS_BOOT_PARTITION_SIZE_MB,
#   PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB, PANICOS_AW_BOOT_PACKAGE_BLOCK
#   (cmd-build-image.sh renders the optional boot_package.fex partition block).

image boot.vfat {
	vfat {
		extraargs = "-F 32 -n PANICOS"
		files = {
			"Image",
			"dtb.img",
			"dtbs",
			"extlinux",
			"panicos-active.cfg",
			"panicos-wifi.cfg",
			"initramfs.cpio.gz",
			"${PANICOS_OUTPUT_NAME}.squashfs",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image storage.ext4 {
	ext4 {
		label = "storage"
	}
	size = ${PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB}M
}

image ${PANICOS_OUTPUT_NAME}.img {
	hdimage { }

	partition spl {
		in-partition-table = "no"
		image = "boot0.img"
		offset = 8K
	}

${PANICOS_AW_BOOT_PACKAGE_BLOCK}
	partition boot {
		partition-type = 0xC
		bootable = "true"
		image = "boot.vfat"
	}

	partition storage {
		partition-type = 0x83
		image = "storage.ext4"
	}
}

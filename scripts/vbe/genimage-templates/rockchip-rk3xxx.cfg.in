# Rockchip RK3xxx disk image — generated by vbe build-image.
#
# GPT layout (mirrors board/anbernic/rg353p/genimage.cfg.in):
#   Sector 0-63     (0-31K):    GPT header
#   Offset 32K:                 idbloader.img + u-boot.itb (as u-boot-rockchip-vbe.bin)
#   Offset 16M:                 boot FAT32 partition (kernel Image + DTBs + boot.scr)
#   After boot:                 system ext4 partition (squashfs payload)
#   After system:               overlay ext4 partition (writable user data)
#
# Two separate blobs (idbloader.img at 32K, u-boot.itb at 8M) are concatenated
# by cmd-build-image.sh into u-boot-rockchip-vbe.bin before genimage runs, so
# a single in-partition-table=no entry covers the full bootloader area.
#
# Envsubst tokens: PANICOS_OUTPUT_NAME, PANICOS_BOOT_PARTITION_SIZE_MB,
#   PANICOS_SYSTEM_PARTITION_SIZE_MB, PANICOS_OVERLAY_PARTITION_INITIAL_SIZE_MB

image boot.vfat {
	vfat {
		files = {
			"Image",
			"dtb.img",
			"dtbs",
			"boot.scr",
			"panicos-active.cfg",
			"initramfs.cpio.gz",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image system.ext4 {
	ext4 { }
	size = ${PANICOS_SYSTEM_PARTITION_SIZE_MB}M
}

image overlay.ext4 {
	ext4 { }
	size = ${PANICOS_OVERLAY_PARTITION_INITIAL_SIZE_MB}M
}

image ${PANICOS_OUTPUT_NAME}.img {
	hdimage {
		partition-table-type = "gpt"
		align = "1M"
	}

	partition u-boot {
		in-partition-table = "no"
		image = "u-boot-rockchip-vbe.bin"
		offset = 32K
	}

	partition boot {
		partition-type-uuid = "C12A7328-F81F-11D2-BA4B-00A0C93EC93B"
		bootable = "true"
		image = "boot.vfat"
		offset = 16M
	}

	partition system {
		partition-type-uuid = "0FC63DAF-8483-4772-8E79-3D69D8477DE4"
		image = "system.ext4"
	}

	partition overlay {
		partition-type-uuid = "0FC63DAF-8483-4772-8E79-3D69D8477DE4"
		image = "overlay.ext4"
	}
}

# Rockchip RK3xxx disk image — generated by vbe build-image.
# Two-partition design (matches board/anbernic/rg353p/genimage.cfg.in):
#   Sector 0-63     (0-31K):    GPT header
#   Offset 32K:                 idbloader.img + u-boot.itb (concat'd as
#                               u-boot-rockchip-vbe.bin by cmd-build-image.sh)
#   p1  boot FAT32 — kernel Image + DTB(s) + extlinux.conf + *.squashfs flavors
#                    + panicos-active.cfg, offset 16M
#   p2  storage ext4 — user data + .panicos-overlay/ (firstboot grows to fill SD)
#
# Envsubst tokens: PANICOS_OUTPUT_NAME, PANICOS_BOOT_PARTITION_SIZE_MB,
#   PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB

image boot.vfat {
	vfat {
		extraargs = "-F 32 -n PANICOS"
		files = {
			"Image",
			"dtb.img",
			"dtbs",
			"extlinux",
			"panicos-active.cfg",
			"panicos-wifi.cfg",
			"initramfs.cpio.gz",
			"${PANICOS_OUTPUT_NAME}.squashfs",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image storage.ext4 {
	ext4 {
		label = "storage"
	}
	size = ${PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB}M
}

image ${PANICOS_OUTPUT_NAME}.img {
	hdimage {
		partition-table-type = "gpt"
		align = "1M"
	}

	partition u-boot {
		in-partition-table = "no"
		image = "u-boot-rockchip-vbe.bin"
		offset = 32K
	}

	partition boot {
		partition-type-uuid = "C12A7328-F81F-11D2-BA4B-00A0C93EC93B"
		bootable = "true"
		image = "boot.vfat"
		offset = 16M
	}

	partition storage {
		partition-type-uuid = "0FC63DAF-8483-4772-8E79-3D69D8477DE4"
		image = "storage.ext4"
	}
}

#!/bin/sh
# SPDX-License-Identifier: GPL-2.0
# Copyright (C) 2025 ROCKNIX (https://github.com/ROCKNIX)

. /etc/profile
# pgrep -x on procps-ng refuses patterns >15 chars (kernel comm limit) and
# returns no matches for "emulationstation" (17 chars). Use pidof, which
# matches full /proc/PID/exe basename and works regardless. Without this,
# the script silently exits 0 every hotplug event and never switches outputs.
if ! pidof emulationstation > /dev/null 2>&1; then
  exit 0
fi

HDMI_OUTPUT=$(wlr-randr | awk '/^(HDMI-A|DP|DisplayPort)-[0-9]*/ {print $1}')
DSI_OUTPUT=$(wlr-randr | awk '/^DSI-[0-9]/ {print $1}')

HDMI_STATE=$(cat /run/hdmi-status.last 2>/dev/null)

# Returns 0 if the named wlr-randr output is currently enabled.
#
# NOTE: `exit 0` from a matching rule does NOT set the final status here --
# awk transfers control to END, and an `exit` in END overrides it. The old
# code had `END { exit 1 }`, which clobbered every success back to 1, so this
# function ALWAYS reported "not enabled". That broke the idempotency guards
# below: handle-hdmi-hotplug then ran `killall emulationstation` on the single
# boot-time "disconnected" baseline event, restarting ES ~30s into every cold
# boot. Use a `found` flag and let END alone decide the exit status.
output_enabled() {
    wlr-randr 2>/dev/null | awk -v o="$1" '
        $1 == o { f=1 }
        f && /Enabled: yes/ { found=1; exit }
        f && /^[^ ]/ && $1 != o { exit }
        END { exit (found ? 0 : 1) }
    '
}

case "${HDMI_STATE}" in
  connected)

    # Stop USB gadget only if using USB-C (DisplayPort) video, as it conflicts with USB data lanes on some SoCs (e.g. RK3588/SM8250)
    # Standard HDMI ports are unaffected.
    if cat /sys/class/drm/card*-DP*/status /sys/class/drm/card*-DisplayPort*/status 2>/dev/null | grep -q "^connected"; then
        if systemctl is-active --quiet usbgadget; then
             systemctl stop usbgadget
        fi
    fi
    if [ -n "${HDMI_OUTPUT}" ]; then
      # Idempotency: if HDMI is already the active output, nothing to do.
      # This prevents an ES-restart loop when the service fires repeatedly.
      output_enabled "${HDMI_OUTPUT}" && exit 0
      # --preferred requires EDID; fall back for adapters (e.g. HDMI-to-VGA)
      # that expose modes without a preferred EDID entry.
      wlr-randr --output "${HDMI_OUTPUT}" --preferred --on 2>/dev/null || \
        wlr-randr --output "${HDMI_OUTPUT}" --mode 1024x768 --on 2>/dev/null || \
        wlr-randr --output "${HDMI_OUTPUT}" --mode 800x600 --on
      if [ -n "${DSI_OUTPUT}" ]; then
        wlr-randr --output "${DSI_OUTPUT}" --off
      fi
      killall emulationstation || true
    fi
    ;;
  disconnected)

    # Stop USB gadget only if using USB-C (DisplayPort) video, as it conflicts with USB data lanes on some SoCs (e.g. RK3588/SM8250)
    # Standard HDMI ports are unaffected.
    if cat /sys/class/drm/card*-DP*/status /sys/class/drm/card*-DisplayPort*/status 2>/dev/null | grep -q "^connected"; then
        if systemctl is-active --quiet usbgadget; then
             systemctl stop usbgadget
        fi
    fi
    if [ -n "${DSI_OUTPUT}" ]; then
      # Idempotency: if DSI is already the active output, nothing to do.
      output_enabled "${DSI_OUTPUT}" && exit 0
      wlr-randr --output "${DSI_OUTPUT}" --preferred --on
      killall emulationstation || true
    fi
    ;;
esac

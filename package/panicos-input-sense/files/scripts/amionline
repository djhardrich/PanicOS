# Report whether the device has network connectivity.
# Original implementation pinged www.google.com with a 1-second timeout,
# which reports "false" whenever the ping fails even if WiFi is fully
# associated — intermittent DNS or Google downtime would flip ES's
# "Network Settings" to "not connected". Use nmcli's own connectivity
# state instead: "full" or "limited" both mean the interface is up and
# associated; "none"/"portal"/"unknown" mean genuinely offline.

state=$(nmcli -t -f CONNECTIVITY general 2>/dev/null)
case "$state" in
  full|limited)
    echo true
    exit 0
    ;;
  *)
    echo false
    exit 1
    ;;
esac

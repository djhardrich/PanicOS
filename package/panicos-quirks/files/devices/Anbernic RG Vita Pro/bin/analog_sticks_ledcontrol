# Set joystick ring LED color on the RG Vita Pro via the SPI MCU
# joypad kernel driver's multicolor LED interface.

. /etc/profile.d/001-functions

if [ $# -ne 7 ]; then
  echo "Usage: $0 <brightness> <right_red> <right_green> <right_blue> <left_red> <left_green> <left_blue>"
  exit 1
fi

BRIGHTNESS=$1
RIGHT_RED=$2
RIGHT_GREEN=$3
RIGHT_BLUE=$4
LEFT_RED=$5
LEFT_GREEN=$6
LEFT_BLUE=$7

# Discover multicolor LED sysfs paths from the spi-mcu-joypad driver.
LED_LEFT=$(ls -d /sys/class/leds/*::joystick-left 2>/dev/null | head -1)
LED_RIGHT=$(ls -d /sys/class/leds/*::joystick-right 2>/dev/null | head -1)

if [ -z "${LED_LEFT}" ] || [ -z "${LED_RIGHT}" ]; then
  echo "Error: SPI MCU joypad LEDs not found in sysfs"
  exit 1
fi

# Set brightness on both rings.
echo "${BRIGHTNESS}" > "${LED_LEFT}/brightness"
echo "${BRIGHTNESS}" > "${LED_RIGHT}/brightness"

# Set RGB intensity (the multicolor LED subsystem uses multi_intensity).
echo "${LEFT_RED} ${LEFT_GREEN} ${LEFT_BLUE}" > "${LED_LEFT}/multi_intensity"
echo "${RIGHT_RED} ${RIGHT_GREEN} ${RIGHT_BLUE}" > "${LED_RIGHT}/multi_intensity"

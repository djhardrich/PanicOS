# Resume often does not work, disable suspend
/usr/bin/suspendmode off

### Ignore power button presses for now
cat <<EOF >~/.config/logind.conf.d/login.conf
[Login]
HandlePowerKey=ignore
HandleSuspendKey=ignore
EOF

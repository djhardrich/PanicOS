# DHCP on whichever interface the wifi driver brings up. Match by
# device type, not name — sunxi/rockchip kernels typically expose the
# adapter as `wlan0`, but a future SoC using systemd's predictable names
# would call it `wlp1s0` (or similar) and a name-based match would
# silently miss. `Type=wlan` matches both.
#
# Lives in /etc/systemd/network/ so the user can override (static IP
# etc) by dropping a higher-priority file via overlay.
[Match]
Type=wlan

[Network]
DHCP=yes

[DHCPv4]
# Use the MAC as the DHCP client-ID (option 61) instead of systemd's
# default per-machine DUID. Stops routers from handing out a new lease
# every boot just because PanicOS sends a different DUID than ROCKNIX or
# whatever else this device used to run — same MAC + same client-ID =
# stable lease. Most consumer routers index DHCP leases by client-ID
# rather than by MAC alone, so this is the safe portable choice.
ClientIdentifier=mac

config BR2_PACKAGE_PANICOS_GL4ES
	bool "panicos-gl4es"
	depends on BR2_PACKAGE_MESA3D_OPENGL_EGL
	depends on BR2_PACKAGE_SDL2
	help
	  Build gl4es (ptitSeb) as a system library.  Installs libGL.so.1 to
	  /usr/lib/ (system-wide) so PortMaster's gl_check finds it, and
	  symlinks into /usr/lib/gl4es/ for the LD_LIBRARY_PATH override in
	  libgl_PanicOS.txt.

	  Staging install provides libGL.so, GL headers (include/GL/gl.h from
	  the gl4es source tree), and a gl.pc so panicos-libglu can build
	  without going through buildroot's libgl virtual package (which
	  requires X11/GLX that we don't have).

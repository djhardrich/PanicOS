config BR2_PACKAGE_PANICOS_EMULATIONSTATION
	bool "panicos-emulationstation"
	depends on BR2_INIT_SYSTEMD
	depends on BR2_INSTALL_LIBSTDCPP
	depends on BR2_TOOLCHAIN_HAS_THREADS
	select BR2_PACKAGE_SDL2
	select BR2_PACKAGE_SDL2_MIXER
	select BR2_PACKAGE_ALSA_LIB
	select BR2_PACKAGE_FREETYPE
	select BR2_PACKAGE_LIBFREEIMAGE
	select BR2_PACKAGE_LIBCURL
	select BR2_PACKAGE_LIBCURL_OPENSSL
	select BR2_PACKAGE_OPENSSL
	select BR2_PACKAGE_RAPIDJSON
	select BR2_PACKAGE_BOOST
	select BR2_PACKAGE_BOOST_SYSTEM
	select BR2_PACKAGE_BOOST_FILESYSTEM
	select BR2_PACKAGE_BOOST_LOCALE
	select BR2_PACKAGE_BOOST_DATE_TIME
	select BR2_PACKAGE_VLC
	select BR2_PACKAGE_BASH
	select BR2_PACKAGE_FPING
	select BR2_PACKAGE_P7ZIP
	select BR2_PACKAGE_XMLSTARLET
	help
	  ROCKNIX's emulationstation-next fork — the launcher / frontend
	  used by ROCKNIX, Batocera, et al. Configured for KMSDRM
	  rendering via SDL2 + GLES2 (uses the same mesa3d/panfrost stack
	  as the pht flavor). Auto-starts on tty1 via panicos-es.service.

	  VLC is a heavy dep (~30MB in the squashfs, ~15min build cost)
	  but the upstream ES fork unconditionally `find_package(VLC
	  REQUIRED)` and patching it cleanly is more work than the build
	  cost. Pulled in for convenience; gives video previews of games
	  for free.

	  Targets the launcher flavor exclusively right now. Other flavors
	  can pull in PHT or whatever else for their own UI.

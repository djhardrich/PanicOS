config BR2_PACKAGE_PANICOS_PHT
	bool "panicos-pht (ProHandheldTracker)"
	depends on BR2_aarch64
	depends on BR2_TOOLCHAIN_USES_GLIBC
	depends on BR2_INSTALL_LIBSTDCPP    # pht-aarch64 + 3 plugins link libstdc++.so.6
	select BR2_PACKAGE_SDL2
	select BR2_PACKAGE_ALSA_LIB
	help
	  ProHandheldTracker — PortMaster-flavor SDL2 audio tracker.
	  Bundles the prebuilt aarch64 binary, ~50MB of plugin DSPs, and
	  a launcher tuned for handheld use (sets SDL_AUDIODRIVER=pipewire,
	  exports SDL_GAMECONTROLLERCONFIG from the bundled gamecontrollerdb).

	  Payload comes from vendor/pht/ in the repo. Run scripts/vendor-pht.sh
	  to populate that directory from your local
	  ~/prohandheldtracker-build/dist/stage/pht. Build will fail with a
	  clear error if vendor/pht/bin/pht-aarch64 is absent.

	  Pairs with the "pht" flavor (pht autostarts at boot under chrt) or
	  can be installed in any flavor for a launch-on-demand setup.

if BR2_PACKAGE_PANICOS_PHT

config BR2_PACKAGE_PANICOS_PHT_AUTOSTART
	bool "autostart on boot (replaces tty1 getty)"
	depends on BR2_INIT_SYSTEMD
	help
	  Install panicos-pht.service into multi-user.target.wants and have
	  it Conflicts=getty@tty1.service. PHT takes the panel via KMSDRM
	  master, so when the unit starts systemd shuts down the tty1 getty
	  to avoid fbcon fighting PHT for the framebuffer.

	  On by default for the "pht" flavor. Disable if you want to launch
	  PHT manually (e.g. from SSH for debugging).

endif # BR2_PACKAGE_PANICOS_PHT

[Unit]
Description=Copyparty HTTP file server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/bin/copyparty.pyz \
    --port 3923 \
    --name PanicOS \
    -v /storage::r:c:c,e2dsa,e2ts \
    --no-reload
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target

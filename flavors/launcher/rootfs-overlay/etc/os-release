NAME=PanicOS
VERSION=1.0
ID=panicos
VERSION_ID=1.0
PRETTY_NAME="PanicOS 1.0"
HOME_URL="https://github.com/djhardrich/PanicOS"

# OS_NAME is what PortMaster's device_info.txt CFW detection ladder
# settles on (line 126 fallback: `CFW_NAME=$(grep -a '^OS_NAME=".*"' /etc/os-release | cut -d'"' -f 2)`).
# Setting it to "PanicOS" makes PortMaster look for mod_PanicOS.txt —
# which we ship via panicos-launcher-tools and panicos-firstboot drops
# into /storage/roms/ports/PortMaster/ after PortMaster.zip extraction.
# Equivalent to ROCKNIX's contract (sway fullscreen via swaymsg) but
# under our own name — no ROCKNIX branding shipped.
OS_NAME="PanicOS"
OS_VERSION="1.0"

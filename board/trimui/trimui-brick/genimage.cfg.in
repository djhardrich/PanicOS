# TrimUI Brick disk image — Allwinner A133 layout.
#
# Allwinner A133 eMMC/SD layout (standard Allwinner sunxi):
#   GPT header at offset 81920 (0x14000) — moved to avoid BROM area
#   boot0.img   (in-partition-table=no) at offset 131072 (0x20000)
#     Allwinner A133 eGON.BT0 stage1 BROM blob, 64KB. The A133 BROM
#     scans for boot0 at 0x20000 on SD card — confirmed by every Knulli
#     A133 genimage.cfg (trimui-brick, TSP, powkiddy-v20, v90s, mx-zero-28).
#   boot_package.fex (in-partition-table=no) at offset 16793600 (0x1004000)
#     Allwinner TOC1 package: U-Boot + ATF + SCP + DTB, ~4.6MB
#   boot.img    partition at offset 37748736 (0x2400000)
#     Android bootimg with vendor kernel + ramdisk (~15MB)
#   env.img     partition (after boot.img)
#     U-Boot environment partition (128KB)
#   boot        VFAT, bootable — holds kernel uImage, boot scripts, PanicOS squashfs
#   system      ext4 — holds squashfs image payload
#   overlay     ext4 — writable user data
#
# Blob files (boot0.img, boot_package.fex, boot.img, env.img) are staged
# verbatim from soc/allwinner-a133/vendor/prebuilt/trimui-brick/partitions/
# by post-image.sh via panicos_blob_mode_stage().
#
# Sizes from PANICOS_*_PARTITION_SIZE_MB Kconfigs,
# substituted at build time by post-image.sh via envsubst.

image boot.vfat {
	vfat {
		# Vendor initrd looks for `label=BATOCERA` partition. Match
		# Knulli's labeling so the vendor early-init flow doesn't fail.
		extraargs = "-F 32 -n BATOCERA"
		files = {
			"uImage",
			"boot/boot.scr",
			"boot/extlinux.conf",
			"boot/boot.cmd",
			"boot/bootlogo.bmp",
			"boot/font24.sft",
			"boot/font32.sft",
			"boot/magic.bin",
			"boot/asound.state",
			"boot/bat",
			"panicos-active.cfg",
			"panicos-wifi.cfg",
			"${PANICOS_OUTPUT_NAME}.squashfs",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image storage.ext4 {
	ext4 {
		label = "storage"
	}
	size = ${PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB}M
}

image ${PANICOS_OUTPUT_NAME}.img {
	hdimage {
		partition-table-type = "gpt"
		align = "1M"
		gpt-location = 81920
	}

	partition bootloader {
		in-partition-table = "no"
		image = "partitions/boot0.img"
		# A133 BROM scans for boot0 at 0x20000 (131072) on SD.
		# 0x40000 was wrong — BROM never found it, fell back to eMMC.
		offset = 131072
	}

	partition boot-package {
		in-partition-table = "no"
		image = "partitions/boot_package.fex"
		offset = 16793600
	}

	# Named "boot" to match the Allwinner partition table inside boot_package.fex
	# (env: boot_partition=boot). sunxi_flash reads by Allwinner name, not GPT name,
	# but keeping them consistent avoids confusion.
	partition boot {
		image = "partitions/boot.img"
		offset = 37748736
	}

	partition env {
		image = "partitions/env.img"
	}

	# Vendor U-Boot looks for a redundant env partition right after the
	# primary one — Knulli ships both. Without env-redund, U-Boot may stall
	# during env load on some devices.
	partition env-redund {
		image = "partitions/env.img"
	}

	# Knulli names this "boot-resource". Type "F" (FAT) matches Knulli exactly.
	partition boot-resource {
		partition-type-uuid = "F"
		bootable = "true"
		image = "boot.vfat"
	}

	partition storage {
		partition-type-uuid = "0FC63DAF-8483-4772-8E79-3D69D8477DE4"
		image = "storage.ext4"
	}
}

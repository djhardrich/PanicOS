# TrimUI Brick disk image — mainline kernel flavor.
#
# Partition layout is identical to vendor mode (same offsets, same partition
# numbers) so the vendor U-Boot finds the boot VFAT on the expected partition.
# Differences from genimage.cfg.in:
#   - VFAT includes mainline Image + DTB instead of prebuilt uImage.
#   - boot-fw partition still holds the vendor Android bootimg as an emergency
#     fallback (vendor U-Boot falls back to it if boot.scr fails to boot).
#   - No panicos-bootimg-ramdisk: initramfs is baked into the kernel Image.

image boot.vfat {
	vfat {
		extraargs = "-F 32 -n BATOCERA"
		files = {
			"boot/Image",
			"boot/sun50i-a133-trimui-brick.dtb",
			"boot/boot.scr",
			"boot/extlinux.conf",
			"boot/boot.cmd",
			"boot/bootlogo.bmp",
			"boot/font24.sft",
			"boot/font32.sft",
			"boot/magic.bin",
			"boot/asound.state",
			"boot/bat",
			"panicos-active.cfg",
			"panicos-wifi.cfg",
			"${PANICOS_OUTPUT_NAME}.squashfs",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image storage.ext4 {
	ext4 {
		label = "storage"
	}
	size = ${PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB}M
}

image ${PANICOS_OUTPUT_NAME}.img {
	hdimage {
		partition-table-type = "gpt"
		align = "1M"
		gpt-location = 81920
	}

	partition bootloader {
		in-partition-table = "no"
		image = "partitions/boot0.img"
		# A133 BROM scans for boot0 at 0x40000 (262144). Confirmed from
		# Knulli's genimage.cfg for all A133 devices.
		offset = 262144
	}

	partition boot-package {
		in-partition-table = "no"
		image = "partitions/boot_package.fex"
		offset = 16793600
	}

	# Keep vendor Android bootimg as fallback — vendor U-Boot boots this
	# if boot.scr is absent or fails. Allows recovery by re-flashing VFAT.
	partition boot-fw {
		image = "partitions/boot.img"
		offset = 37748736
	}

	partition env {
		image = "partitions/env.img"
	}

	partition env-redund {
		image = "partitions/env-redund.img"
	}

	partition boot {
		partition-type-uuid = "C12A7328-F81F-11D2-BA4B-00A0C93EC93B"
		bootable = "true"
		image = "boot.vfat"
	}

	partition storage {
		partition-type-uuid = "0FC63DAF-8483-4772-8E79-3D69D8477DE4"
		image = "storage.ext4"
	}
}

# RK3326-b disk image. MBR (DOS) partition table — RK3326 U-Boot requires MBR.
#   p1  boot vfat    (~6GB) — kernel Image, rk3326-*.dtb (at root), boot.scr,
#                              extlinux/, *.squashfs flavors, panicos-active.cfg.
#   p2  storage ext4 (rest) — user data + .panicos-overlay/ (firstboot grows).
#
# uboot.bin (ROCKNIX-style rkhelper assembly: idbloader + uboot.img + trust.img)
# is written at 32K offset — before partition 1 starts at 16M. See
# soc/rockchip-rk3326/uboot/build-uboot-rockchip.sh for the why-not-binman.
#
# DTBs live at the FAT root (FDTDIR / in extlinux.conf, matching ROCKNIX).
# The DTB list below is injected by post-image.sh via envsubst.

image boot.vfat {
	vfat {
		extraargs = "-F 32 -n PANICOS"
		files = {
			"Image",
${PANICOS_DTB_FILES}			"boot.scr",
			"extlinux",
			"panicos-active.cfg",
			"panicos-wifi.cfg",
			"${PANICOS_OUTPUT_NAME}.squashfs",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image storage.ext4 {
	ext4 {
		label = "storage"
	}
	size = ${PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB}M
}

image ${PANICOS_OUTPUT_NAME}.img {
	hdimage {
		partition-table-type = "mbr"
		align = "1M"
	}

	partition u-boot {
		in-partition-table = "no"
		image = "uboot.bin"
		offset = 32K
	}

	partition boot {
		partition-type = "0xc"
		bootable = "true"
		image = "boot.vfat"
		offset = 16M
	}

	partition storage {
		partition-type = "0x83"
		image = "storage.ext4"
	}
}

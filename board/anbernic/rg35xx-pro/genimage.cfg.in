# RG35XX Pro disk image — two-partition design.
#   p1  boot vfat    (~6GB) — kernel, DTB, extlinux.conf, *.squashfs flavors,
#                              panicos-active.cfg pointing at one of them.
#                              FAT so PC users can drag-and-drop squashfs
#                              flavors / edit the active.cfg without tooling.
#   p2  storage ext4 (rest) — user data + .panicos-overlay/ (system writable
#                              layer for overlayfs). Grown on first boot.
#
# Sizes from PANICOS_*_PARTITION_SIZE_MB Kconfigs, substituted by post-image.sh
# via envsubst.

image boot.vfat {
	vfat {
		extraargs = "-F 32 -n PANICOS"
		files = {
			"Image",
			"dtb.img",
			"dtbs",
			"extlinux",
			"panicos-active.cfg",
			"panicos-wifi.cfg",
			"panicos-modules.tar.gz",
			"${PANICOS_OUTPUT_NAME}.squashfs",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image storage.ext4 {
	ext4 {
		label = "storage"
	}
	size = ${PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB}M
}

image ${PANICOS_OUTPUT_NAME}.img {
	hdimage {
	}

	partition u-boot {
		in-partition-table = "no"
		image = "u-boot-sunxi-with-spl.bin"
		offset = 8K
	}

	partition boot {
		partition-type = 0xC
		bootable = "true"
		image = "boot.vfat"
	}

	partition storage {
		partition-type = 0x83
		image = "storage.ext4"
	}
}

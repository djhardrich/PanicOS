# RG353P disk image — Rockchip RK3566 layout.
#
# Rockchip SD/eMMC layout (standard for RK356x):
#   Sector 0-63     (0-31K):    MBR/GPT header
#   Sector 64       (32K):      idbloader + u-boot.itb combined blob (u-boot-rockchip.bin)
#   Partition table entry starts after U-Boot area
#   Boot partition  (~16M):     FAT32, kernel Image + DTBs + boot.scr
#   System partition:           ext4, squashfs payload
#   Overlay partition:          ext4, writable user data
#
# u-boot-rockchip.bin is assembled by binman during U-Boot build when
# BR2_TARGET_UBOOT_NEEDS_ROCKCHIP_RKBIN=y. It includes idbloader.img
# (SPL + DDR TPL) and u-boot.itb (U-Boot proper + BL31 FIT image) and
# is designed to be written as a single blob starting at offset 32K.
#
# Sizes from PANICOS_*_PARTITION_SIZE_MB Kconfigs,
# substituted at build time by post-image.sh via envsubst.

image boot.vfat {
	vfat {
		files = {
			"Image",
			"dtb.img",
			"dtbs",
			"boot.scr",
			"panicos-active.cfg",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image system.ext4 {
	ext4 {
		# Files added at image-staging time by post-image.sh.
	}
	size = ${PANICOS_SYSTEM_PARTITION_SIZE_MB}M
}

image overlay.ext4 {
	ext4 { }
	size = ${PANICOS_OVERLAY_PARTITION_INITIAL_SIZE_MB}M
}

image panicos-rg353p-minimal.img {
	hdimage {
		partition-table-type = "gpt"
		align = "1M"
	}

	partition u-boot {
		in-partition-table = "no"
		image = "u-boot-rockchip.bin"
		offset = 32K
	}

	partition boot {
		partition-type-uuid = "C12A7328-F81F-11D2-BA4B-00A0C93EC93B"
		bootable = "true"
		image = "boot.vfat"
		offset = 16M
	}

	partition system {
		partition-type-uuid = "0FC63DAF-8483-4772-8E79-3D69D8477DE4"
		image = "system.ext4"
	}

	partition overlay {
		partition-type-uuid = "0FC63DAF-8483-4772-8E79-3D69D8477DE4"
		image = "overlay.ext4"
	}
}

# RG35XX Pro LPDDR3 disk image — two-partition design (see rg35xx-pro/genimage.cfg.in).

image boot.vfat {
	vfat {
		extraargs = "-F 32 -n PANICOS"
		files = {
			"Image",
			"dtb.img",
			"dtbs",
			"extlinux",
			"panicos-active.cfg",
			"panicos-wifi.cfg",
			"panicos-rg35xx-pro-lpddr3-minimal.squashfs",
		}
	}
	size = ${PANICOS_BOOT_PARTITION_SIZE_MB}M
}

image storage.ext4 {
	ext4 {
		label = "storage"
	}
	size = ${PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB}M
}

image panicos-rg35xx-pro-lpddr3-minimal.img {
	hdimage {
	}

	partition u-boot {
		in-partition-table = "no"
		image = "u-boot-sunxi-with-spl.bin"
		offset = 8K
	}

	partition boot {
		partition-type = 0xC
		bootable = "true"
		image = "boot.vfat"
	}

	partition storage {
		partition-type = 0x83
		image = "storage.ext4"
	}
}

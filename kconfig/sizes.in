menu "Image partition sizes"
	depends on !PANICOS_SOC_NONE

config PANICOS_BOOT_PARTITION_SIZE_MB
	int "Boot partition size (MB)"
	default 6144
	help
	  FAT32 boot partition. Holds the kernel + DTB(s), extlinux.conf,
	  panicos-active.cfg, and one or more .squashfs flavors. PC users can
	  drag-and-drop additional .squashfs files onto this partition and
	  edit panicos-active.cfg to switch the active flavor — no Linux-fs
	  driver required.

	  Default 6GB fits one ~2GB squashfs comfortably plus headroom for
	  a second flavor and DTBs. Bump higher if you ship more flavors.

config PANICOS_STORAGE_PARTITION_INITIAL_SIZE_MB
	int "Storage partition initial size (MB)"
	default 64
	help
	  ext4 partition that holds user data (ROMs, saves) AND the system
	  overlayfs upper+work dirs (under /storage/.panicos-overlay/). Grown
	  to fill free SD space on first boot by the panicos-firstboot service.

endmenu

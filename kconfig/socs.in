choice
	prompt "SoC family (selected by device)"
	default PANICOS_SOC_NONE

config PANICOS_SOC_NONE
	bool "(none — harness-smoke / generic)"

source "$BR2_EXTERNAL_PANICOS_PATH/soc/allwinner-h700/Config.in"
source "$BR2_EXTERNAL_PANICOS_PATH/soc/allwinner-a133/Config.in"
source "$BR2_EXTERNAL_PANICOS_PATH/soc/rockchip-rk3566/Config.in"

endchoice

choice
	prompt "Kernel flavor"
	default PANICOS_KERNEL_FLAVOR_MAINLINE
	depends on !PANICOS_SOC_NONE && !PANICOS_SOC_ALLWINNER_A133

config PANICOS_KERNEL_FLAVOR_MAINLINE
	bool "mainline"
	help
	  Linux mainline (kernel.org) + ROCKNIX patches.

config PANICOS_KERNEL_FLAVOR_VENDOR
	bool "vendor"
	help
	  Vendor BSP kernel — Linux 4.9.170 from Orange Pi Xunlong's
	  fork (the same source Knulli uses), built from source by us.
	  Useful for devices where mainline support is incomplete or
	  where vendor-only features (RT patches, certain peripherals)
	  are needed.

	  Note: closed-source vendor SoCs (e.g. Allwinner A133 in the
	  TrimUI Brick) cannot use this flavor — they require blob-only
	  build mode handled per-device (see Plan 04).

endchoice

config PANICOS_KERNEL_FLAVOR_NAME
	string
	default "mainline" if PANICOS_KERNEL_FLAVOR_MAINLINE
	default "vendor" if PANICOS_KERNEL_FLAVOR_VENDOR
	default "vendor" if PANICOS_SOC_ALLWINNER_A133

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: PanicOS <panicos@localhost>
Date: Tue, 05 May 2026 00:00:00 +0000
Subject: [PATCH] egl: embed wl_fixes protocol code for older wayland compat

PortMaster's bundled westonwrap injects its own older libwayland-client.so
into LD_LIBRARY_PATH ahead of /lib64.  That older wayland predates the
wl_fixes interface (added in wayland 1.22), so Mesa 26's libEGL.so fails
to load with:

  undefined symbol: wl_fixes_interface

Fix by generating the wl_fixes protocol code directly into libEGL.so so
wl_fixes_interface is defined locally rather than imported from
libwayland-client.so at load time.  The generated code is compiled with
include_core_only=true so only the new interface is embedded; core types
like wl_registry remain resolved from libwayland-client.so as before.

The compositor will never advertise wl_fixes unless it is a recent
wayland 1.22+ server, so dri2_dpy->wl_fixes stays NULL for PortMaster's
old bundled weston and the new code-paths are effectively no-ops there.
---
 src/egl/meson.build       | 10 ++++++++++
 src/egl/wayland-fixes.xml | 48 ++++++++++++++++++++++++++++++++++++++
 2 files changed, 58 insertions(+)
 create mode 100644 src/egl/wayland-fixes.xml

diff --git a/src/egl/meson.build b/src/egl/meson.build
--- a/src/egl/meson.build
+++ b/src/egl/meson.build
@@ -124,6 +124,16 @@
     files_egl += files('drivers/dri2/platform_wayland.c')
     files_egl += wp_files['linux-dmabuf-unstable-v1']
     files_egl += wp_files['presentation-time']
+    # Embed wl_fixes protocol code so that wl_fixes_interface is defined inside
+    # libEGL.so itself rather than imported from libwayland-client.so at runtime.
+    # Without this, PortMaster's bundled older libwayland-client.so injected via
+    # LD_LIBRARY_PATH causes libEGL.so to fail to load with:
+    #   undefined symbol: wl_fixes_interface
+    _wl_fixes_proto = mod_wl.scan_xml(
+      files('wayland-fixes.xml'),
+      include_core_only : true,
+    )
+    files_egl += _wl_fixes_proto[0]
     if with_wayland_bind_display
       files_egl += [wayland_drm_client_protocol_h]
       link_for_egl += [libwayland_drm]
diff --git a/src/egl/wayland-fixes.xml b/src/egl/wayland-fixes.xml
new file mode 100644
--- /dev/null
+++ b/src/egl/wayland-fixes.xml
@@ -0,0 +1,52 @@
+<?xml version="1.0" encoding="UTF-8"?>
+<protocol name="wayland_fixes_private">
+  <copyright>

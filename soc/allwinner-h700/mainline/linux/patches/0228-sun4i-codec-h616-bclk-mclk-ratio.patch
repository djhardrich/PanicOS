From: PanicOS <panicos@localhost>
Subject: sun4i-codec: fix H616 internal codec half-speed audio

H616 internal codec I2S generates BCLK at a fixed MCLK/16 ratio and always
uses 32-bit slots regardless of sample format, so the generic
sun4i_codec_get_mod_freq() path clocks LRCLK at half the target rate.
Add fixed_bclk_div/i2s_slot_width quirks, precompute mclk_mult = sw*2*div
(= 1024 for H616), and use MCLK = rate * mclk_mult in hw_params.

See docs/h700-hdmi-audio-fixes.md Fix 7. Regenerated as a clean diff against
mainline 7.0.2 (the prior patch's hand-authored hunk counts + inter-hunk blank
lines only ever applied its first hunk, dropping the actual fix).

Signed-off-by: PanicOS <panicos@localhost>
---
--- a/sound/soc/sunxi/sun4i-codec.c	2026-05-29 22:33:52.950750260 -0700
+++ b/sound/soc/sunxi/sun4i-codec.c	2026-05-29 22:38:03.547393405 -0700
@@ -341,6 +341,10 @@
 
 	struct snd_dmaengine_dai_dma_data	capture_dma_data;
 	struct snd_dmaengine_dai_dma_data	playback_dma_data;
+
+	/* mclk_mult != 0: MCLK = rate * mclk_mult (H616 fixed-ratio path).
+	 * 0 means use the legacy sun4i_codec_get_mod_freq() table. */
+	u32 mclk_mult;
 };
 
 static void sun4i_codec_start_playback(struct sun4i_codec *scodec)
@@ -657,9 +661,13 @@
 	unsigned long clk_freq;
 	int ret, hwrate;
 
-	clk_freq = sun4i_codec_get_mod_freq(params);
-	if (!clk_freq)
-		return -EINVAL;
+	if (scodec->mclk_mult) {
+		clk_freq = (unsigned long)params_rate(params) * scodec->mclk_mult;
+	} else {
+		clk_freq = sun4i_codec_get_mod_freq(params);
+		if (!clk_freq)
+			return -EINVAL;
+	}
 
 	ret = clk_set_rate(scodec->clk_module, clk_freq);
 	if (ret)
@@ -2149,6 +2157,13 @@
 	bool has_reset;
 	bool playback_only;
 	u32 dma_max_burst;
+	/* If non-zero, BCLK is generated at MCLK/fixed_bclk_div by the hardware.
+	 * i2s_slot_width gives the physical I2S slot width in bits (0 = use
+	 * params_physical_width).  hw_params sets:
+	 *   MCLK = rate * slot_width * 2 * fixed_bclk_div
+	 * When 0 the legacy sun4i_codec_get_mod_freq() path is used instead. */
+	u8 fixed_bclk_div;
+	u8 i2s_slot_width;
 };
 
 static const struct sun4i_codec_quirks sun4i_codec_quirks = {
@@ -2238,6 +2253,10 @@
 	.reg_dac_txdata	= SUN8I_H3_CODEC_DAC_TXDATA,
 	.has_reset	= true,
 	.dma_max_burst	= SUN4I_DMA_MAX_BURST,
+	/* H616 codec I2S: BCLK = MCLK/16 (hardware fixed), slot width always
+	 * 32 bits.  MCLK = rate*32*2*16 = rate*1024 -> 49152000 Hz at 48 kHz. */
+	.fixed_bclk_div	= 16,
+	.i2s_slot_width	= 32,
 };
 
 static const struct sun4i_codec_quirks suniv_f1c100s_codec_quirks = {
@@ -2314,6 +2333,11 @@
 		return -ENODEV;
 	}
 
+	if (quirks->fixed_bclk_div) {
+		unsigned int sw = quirks->i2s_slot_width ?: 16;
+		scodec->mclk_mult = sw * 2 * quirks->fixed_bclk_div;
+	}
+
 	scodec->regmap = devm_regmap_init_mmio(&pdev->dev, base,
 					       quirks->regmap_config);
 	if (IS_ERR(scodec->regmap)) {

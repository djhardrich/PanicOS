From 0000000000000000000000000000000000000002 Mon Sep 17 00:00:00 2001
From: PanicOS <noreply@panicos.local>
Date: 2026-04-27 12:00:00 -0700
Subject: [PATCH] Add anbernic_rg35xx_h700_lpddr4_defconfig

Cherry-picked from ROCKNIX commit 8d65b60. Adds the LPDDR4 variant
defconfig — this is the most common retail RG35XX Pro DRAM type.
---
 configs/anbernic_rg35xx_h700_lpddr4_defconfig | 34 +++++++++++++++++++++++++++++++++
 1 file changed, 34 insertions(+)
 create mode 100644 configs/anbernic_rg35xx_h700_lpddr4_defconfig

diff --git a/configs/anbernic_rg35xx_h700_lpddr4_defconfig b/configs/anbernic_rg35xx_h700_lpddr4_defconfig
new file mode 100644
index 0000000..2222222
--- /dev/null
+++ b/configs/anbernic_rg35xx_h700_lpddr4_defconfig
@@ -0,0 +1,34 @@
+CONFIG_ARM=y
+CONFIG_ARCH_SUNXI=y
+CONFIG_DEFAULT_DEVICE_TREE="allwinner/sun50i-h700-anbernic-rg35xx-2024"
+CONFIG_SPL=y
+CONFIG_DRAM_SUNXI_DX_ODT=0x08080808
+CONFIG_DRAM_SUNXI_DX_DRI=0x0e0e0e0e
+CONFIG_DRAM_SUNXI_CA_DRI=0x0e0e
+CONFIG_DRAM_SUNXI_ODT_EN=0x7887bbbb
+CONFIG_DRAM_SUNXI_TPR2=0x1
+CONFIG_DRAM_SUNXI_TPR6=0x40808080
+CONFIG_DRAM_SUNXI_TPR10=0x402f6633
+CONFIG_DRAM_SUNXI_TPR11=0x1b1f1e1c
+CONFIG_DRAM_SUNXI_TPR12=0x06060606
+CONFIG_DRAM_SUNXI_PHY_ADDR_MAP_1=y
+CONFIG_MACH_SUN50I_H616=y
+CONFIG_SUNXI_DRAM_H616_LPDDR4=y
+CONFIG_DRAM_CLK=672
+CONFIG_R_I2C_ENABLE=y
+CONFIG_SPL_I2C=y
+CONFIG_SPL_SYS_I2C_LEGACY=y
+CONFIG_SYS_I2C_MVTWSI=y
+CONFIG_SYS_I2C_SLAVE=0x7f
+CONFIG_SYS_I2C_SPEED=400000
+CONFIG_REGULATOR_AXP=y
+CONFIG_AXP717_POWER=y
+CONFIG_AXP_DCDC2_VOLT=940
+CONFIG_AXP_DCDC3_VOLT=1100
+CONFIG_EFI_LOADER=n
+CONFIG_BOOTDELAY=0
+CONFIG_LED_STATUS=y
+CONFIG_LED_STATUS_GPIO=y
+CONFIG_LED_STATUS0=y
+CONFIG_LED_STATUS_BIT=267
+CONFIG_LED_STATUS_STATE=2
-- 
2.53.0


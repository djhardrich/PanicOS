# PanicOS rootfs is overlayfs(squashfs lower + ext4 upper) set up by
# initramfs. Don't list / here — systemd-remount-fs would try to remount
# the overlay r/w (it already is) and complain.
proc       /proc     proc      defaults            0 0
sysfs      /sys      sysfs     sysfs               0 0
tmpfs      /tmp      tmpfs     mode=1777,nosuid,nodev 0 0
